{
  "name": "@helmet-ai/helmet",
  "version": "0.1.0",
  "description": "CLI and TypeScript client for Finland's Helmet library system (helmet.finna.fi) — check loans, renew books, view holds and fines",
  "author": "Vijay Kodam",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vijaykodam/helmet.git"
  },
  "keywords": [
    "helmet",
    "finna",
    "library",
    "finland",
    "helsinki",
    "cli"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "helmet": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/cli.js",
    "clean": "rm -rf dist",
    "fresh": "pnpm clean && pnpm build",
    "start": "node dist/cli.js",
    "lint": "echo 'add lint'",
    "test": "echo 'add tests'",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@inquirer/prompts": "^5.3.8",
    "cheerio": "^1.0.0-rc.12",
    "tough-cookie": "^4.1.4",
    "undici": "^6.19.8"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.8",
    "@types/node": "^22.13.0",
    "@types/tough-cookie": "^4.0.5",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@9.12.0",
  "publishConfig": {
    "access": "public"
  }
}
