{
  "name": "@helmet-ai/helmet",
  "version": "0.1.0",
  "description": "CLI for Finland's Helmet library system — check loans, renew books, view holds and fines",
  "author": "Vijay Kodam",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vijaykodam/helmet.git",
    "directory": "packages/helmet-cli"
  },
  "keywords": [
    "helmet",
    "finna",
    "library",
    "finland",
    "helsinki",
    "cli"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "helmet": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "echo 'add lint'",
    "test": "echo 'add tests'",
    "start": "node dist/index.js",
    "prepack": "pnpm --filter @helmet-ai/client build && pnpm --filter @helmet-ai/helmet build"
  },
  "dependencies": {
    "@inquirer/prompts": "^5.3.8",
    "@helmet-ai/client": "workspace:^"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
